# LawLink 环境变量模板
# 复制为 .env 后填入真实值。.env 不会进 git，绝不提交。

# —— 数据库 ——
# 本地开发（直连 Postgres）：
DATABASE_URL="postgresql://lawlink:lawlink@localhost:5432/lawlink?schema=public"

# Postgres 容器变量（仅 docker compose 用）
POSTGRES_DB=lawlink
POSTGRES_USER=lawlink
POSTGRES_PASSWORD=lawlink
POSTGRES_PORT=5432

# —— 鉴权 ——
# 生成方法：openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_OUTPUT_OF_openssl_rand_base64_32"
NEXTAUTH_URL="http://localhost:3000"

# —— 文件存储与加密 ——
APP_STORAGE_DIR="./storage"
# 文件加密主密钥（AES-256-GCM），base64 编码的 32 字节
# 生成方法：openssl rand -base64 32
# ⚠️ 丢失此密钥则所有加密材料不可恢复，独立于数据库备份
STORAGE_ENCRYPTION_KEY="REPLACE_WITH_OUTPUT_OF_openssl_rand_base64_32"

# —— 初始管理员（仅 seed 时使用）——
SEED_ADMIN_EMAIL="admin@lawlink.local"
SEED_ADMIN_PASSWORD="REPLACE_BEFORE_FIRST_LOGIN"
SEED_ADMIN_NAME="系统管理员"
